generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  role        Role
  roomNumber  String?
  hostelBlock String?
  createdAt   DateTime @default(now())

  complaints  Complaint[]
  bills       Bill[]
  posts       CommunityPost[]
}

model Complaint {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  status      Status   @default(PENDING)
  studentId   String
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  student User @relation(fields: [studentId], references: [id])
}

model Bill {
  id        String   @id @default(uuid())
  studentId String
  month     String
  year      Int
  amount    Float
  status    BillStatus @default(UNPAID)
  dueDate   DateTime
  paidAt    DateTime?

  student User @relation(fields: [studentId], references: [id])
}

model CommunityRoom {
  id    String @id @default(uuid())
  name  String
  type  String

  posts CommunityPost[]
}

model CommunityPost {
  id           String   @id @default(uuid())
  content      String
  isAnonymous  Boolean  @default(false)
  userId       String
  roomId       String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  room CommunityRoom @relation(fields: [roomId], references: [id])
}

enum Role {
  STUDENT
  WARDEN
}

enum Status {
  PENDING
  IN_PROGRESS
  RESOLVED
  ESCALATED
}

enum BillStatus {
  PAID
  UNPAID
}
model CommunityPost {
  id        String   @id @default(uuid())
  content   String
  userId    String
  createdAt DateTime @default(now())
}